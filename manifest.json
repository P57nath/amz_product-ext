{
  "manifest_version": 3,
  "name": "Amazon Review Lens",
  "version": "1.0.0",
  "description": "Floating Amazon product review assistant with multilingual analysis, backend crawling, and optional AI scoring.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.amazon.ca/*",
    "https://*.amazon.co.uk/*",
    "https://*.amazon.de/*",
    "https://*.amazon.fr/*",
    "https://*.amazon.it/*",
    "https://*.amazon.es/*",
    "https://*.amazon.in/*",
    "https://*.amazon.com.au/*",
    "https://*.amazon.ae/*",
    "https://*.amazon.sa/*",
    "https://*.amazon.sg/*",
    "https://*.amazon.nl/*",
    "https://*.amazon.com.br/*",
    "https://*.amazon.com.mx/*",
    "https://*.amazon.co.jp/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "Amazon Review Lens Settings",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.amazon.com/*",
        "https://www.amazon.ca/*",
        "https://www.amazon.co.uk/*",
        "https://www.amazon.de/*",
        "https://www.amazon.fr/*",
        "https://www.amazon.it/*",
        "https://www.amazon.es/*",
        "https://www.amazon.in/*",
        "https://www.amazon.com.au/*",
        "https://www.amazon.ae/*",
        "https://www.amazon.sa/*",
        "https://www.amazon.sg/*",
        "https://www.amazon.nl/*",
        "https://www.amazon.com.br/*",
        "https://www.amazon.com.mx/*",
        "https://www.amazon.co.jp/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
